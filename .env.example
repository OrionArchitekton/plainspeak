# Anthropic API key (server-side only — never exposed to the browser)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Upstash Redis for per-IP rate limiting on the public deployment.
# If both are set, each client is capped at 6 explanations/minute. If unset,
# the API runs without a limit (fine for local dev). Provision via the Vercel
# Marketplace (Upstash Redis) and these are injected automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
