# Anthropic API key (server-side only — never exposed to the browser)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Upstash Redis for per-IP rate limiting on the public deployment.
# If a URL+token pair is set, each client is capped at 6 explanations/minute.
# Either naming works: the Upstash-native names below, or Vercel's KV names
# (KV_REST_API_URL / KV_REST_API_TOKEN), which the Vercel Upstash/KV
# integration injects automatically. Unset = no limit (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
